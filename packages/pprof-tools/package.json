{
  "name": "@mizchi/pprof-tools",
  "version": "0.1.0",
  "description": "Convert Firefox Profiler JSON into pprof, with optional MoonBit-specific demangle and wasm host imports. (V8 cpuprofile → pprof has moved to the Rust crate cpuprofile-to-pprof / `moon-pprof cpuprofile2pprof`.)",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizchi/pprof-mbt.git",
    "directory": "packages/pprof-tools"
  },
  "keywords": [
    "pprof",
    "firefox-profiler",
    "samply",
    "wasmtime",
    "wasm",
    "moonbit",
    "demangle"
  ],
  "exports": {
    "./firefox-to-pprof": "./firefox-to-pprof.mjs",
    "./moonbit/demangle": "./moonbit/demangle.mjs",
    "./moonbit/wasm-host-imports": "./moonbit/wasm-host-imports.mjs"
  },
  "files": [
    "firefox-to-pprof.mjs",
    "moonbit/",
    "README.md"
  ],
  "dependencies": {
    "pprof-format": "^2.2.1"
  }
}
