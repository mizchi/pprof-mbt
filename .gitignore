wasmtime-guest.json

# Rust build artifacts (workspace root)
target/

# moonbit dependency cache (re-fetched by moon)
.mooncakes/
bench-async/_build/

# moonbitlang/x bench artifacts
bench-x/_build/
bench-x/.mooncakes/
