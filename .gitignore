# Ignore ephemeral .claude state (scheduled-task locks, etc.) but
# track .claude/skills/ so per-project skills are versioned with the
# code they describe.
.claude/*
!.claude/skills/

# moonbit build artifacts
bench/_build/

# profile outputs
*.cpuprofile
*.heapprofile
*.pb
*.pb.gz
*.prof
*.syms.json
native-samply.json
