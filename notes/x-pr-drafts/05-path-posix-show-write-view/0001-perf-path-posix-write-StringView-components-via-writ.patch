From 97997b7d2dee0e117331c0db3179b8519fdc03b4 Mon Sep 17 00:00:00 2001
From: claude <chikuba-kotaro@arkedgespace.com>
Date: Sat, 23 May 2026 06:38:06 +0000
Subject: [PATCH] perf(path/posix): write StringView components via write_view
 instead of copying to_owned

---
 path/posix/unix_path.mbt | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/path/posix/unix_path.mbt b/path/posix/unix_path.mbt
index cd88af1..cd05167 100644
--- a/path/posix/unix_path.mbt
+++ b/path/posix/unix_path.mbt
@@ -85,10 +85,10 @@ impl Show for UnixPath with output(self : UnixPath, logger : &Logger) -> Unit {
   match components {
     [] => ()
     [x, .. xs] => {
-      logger.write_string(x.to_owned())
+      logger.write_view(x)
       for x in xs {
         logger.write_char('/')
-        logger.write_string(x.to_owned())
+        logger.write_view(x)
       }
     }
   }
-- 
2.43.0

